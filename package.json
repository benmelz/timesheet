{
  "name": "timesheet",
  "description": "A simple SPA for formatting weekly timesheets.",
  "version": "1.0.0",
  "author": "benmelz",
  "license": "MIT",
  "dependencies": {
    "bootstrap": "^5.2.3",
    "esbuild": "^0.16.3",
    "sass": "^1.56.2"
  },
  "devDependencies": {
    "eslint": "^8.29.0",
    "eslint-config-google": "^0.14.0",
    "serve": "^14.1.2",
    "stylelint": "^14.16.0",
    "stylelint-config-standard-scss": "^6.1.0"
  },
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "sass ./src/:./public/ --no-source-map --load-path=node_modules",
    "build:js": "esbuild src/*.js --bundle --outdir=public",
    "lint:js": "eslint .",
    "lint:css": "stylelint ./**/*.scss",
    "serve": "serve public/"
  }
}
